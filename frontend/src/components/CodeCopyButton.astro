<style is:global>
  .view pre {
    position: relative;
  }

  /* Copy button design */
  .view .code-copy-btn {
    position: absolute;
    top: 8px;
    right: 8px;
    opacity: 0; /* Invisible for default */
    transition:
      opacity 0.2s ease,
      background-color 0.2s ease;
    padding: 4px 10px;
    font-size: 0.85rem;
    background-color: #2563eb; /* Common blue */
    color: #ffffff;
    border: none;
    border-radius: 4px;
    cursor: pointer;
    z-index: 10;
  }

  /* Show button if hover or focus in */
  .view pre:hover .code-copy-btn,
  .view pre:focus-within .code-copy-btn,
  .view .code-copy-btn:focus {
    opacity: 1;
  }

  /* Focus color */
  .view .code-copy-btn:hover {
    background-color: #1d4ed8;
  }

  /* Screen reader only */
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>

<!-- Runtime behavior script -->
<script>
  function initCodeCopyButtons() {
    const preElements = document.querySelectorAll(".view pre");

    preElements.forEach((node) => {
      const pre = node as HTMLPreElement;
      if (pre.querySelector(".code-copy-btn")) return;

      // Create the copy button element with accessibility support
      const button = document.createElement("button");
      button.type = "button";
      button.className = "code-copy-btn";
      button.setAttribute("aria-label", "코드 복사"); // Let screen readers know the purpose of this button
      button.innerText = "복사";

      // Set up a live region to announce the copy success message to screen readers
      const liveRegion = document.createElement("span");
      liveRegion.className = "sr-only";
      liveRegion.setAttribute("aria-live", "polite"); // Screen readers read out changes immediately
      pre.appendChild(liveRegion);

      // Bind the copy event
      button.addEventListener("click", async () => {
        // Use the code tag's text if present inside pre, otherwise use the full pre text
        const codeElement = pre.querySelector("code");
        const textToCopy = codeElement ? codeElement.innerText : pre.innerText;

        try {
          // Copy straight to the clipboard
          await navigator.clipboard.writeText(textToCopy);

          // Update the UI and ARIA state on success
          button.innerText = "완료!";
          button.setAttribute("aria-label", "복사 완료");
          liveRegion.innerText = "코드가 클립보드에 복사되었어요.";

          // Roll back to the original state after 2 seconds
          setTimeout(() => {
            button.innerText = "복사";
            button.setAttribute("aria-label", "코드 복사");
            liveRegion.innerText = "";
          }, 2000);
        } catch (err) {
          liveRegion.innerText = "코드 복사에 실패했어요.";
        }
      });

      // Append the button as the last child inside the pre tag
      pre.appendChild(button);
    });
  }

  // Run on the initial page load
  initCodeCopyButtons();

  // Re-run to rebind whenever the page is swapped in Astro ClientRouter SPA mode
  document.addEventListener("astro:page-load", initCodeCopyButtons);
</script>
