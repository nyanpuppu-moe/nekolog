---
import { PUBLIC_SITE_NAME } from "astro:env/client";
---

<header>
  <div class="holder">
    <p class="site-name">{PUBLIC_SITE_NAME}</p>
  </div>
  <div class="holder">
    <p>{PUBLIC_SITE_NAME}</p>
  </div>
</header>

<style>
  @layer core {
    header {
      display: flex;
      justify-content: space-between;
      position: sticky;
      top: 0;
      height: 3rem;
      z-index: 1000;
      background: var(--crepe-color-background);
      color: var(--crepe-color-on-background);

      .holder {
        display: flex;
        align-items: center;
      }

      p {
        margin: 0;
        padding: 0;
      }
    }
  }

  @layer print {
    @media print {
      header {
        display: none;
      }
    }
  }
</style>
